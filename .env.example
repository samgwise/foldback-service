# Foldback Service Configuration
# Copy this file to .env and update with your values

# LLM Provider: ollama or openai
FOLDBACK_LLM_PROVIDER=ollama

# Ollama Settings
FOLDBACK_OLLAMA_MODEL=qwen2.5:14b

# OpenAI-Compatible API Settings (also used for Ollama's OpenAI-compatible endpoint)
FOLDBACK_OPENAI_BASE_URL=http://localhost:11434/v1
FOLDBACK_OPENAI_API_KEY=
FOLDBACK_OPENAI_MODEL=qwen2.5:14b

# Ollama Context and Generation Limits
FOLDBACK_NUM_CTX=16384
FOLDBACK_NUM_PREDICT=1024

# Server Settings
FOLDBACK_PORT=8100
FOLDBACK_HOST=0.0.0.0

# Logging
FOLDBACK_LOG_LEVEL=INFO

# STT Settings
FOLDBACK_STT_MODEL=large-v3
FOLDBACK_STT_DEVICE=cuda
FOLDBACK_STT_COMPUTE_TYPE=float16
